  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "- Move namespace from http://pgxo.loria.fr/ to http://ns.inria.fr/pgxo/\n- Remove usage of DUL\n- Add a new data property to connect pharmacogenomic relationships to their level of evidence in ClinPGx"
  }, {
    "@language" : "en",
    "@value" : "PGxO aims at providing a small set of concepts and roles that may type elements of pharmacogenomic relationships."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PGxO: a lite Pharmacogenomic Ontology"
