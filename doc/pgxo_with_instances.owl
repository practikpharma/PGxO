        <rdfs:label xml:lang="en">has not chance increased by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/increases -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/increases">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/influences"/>
        <owl:inverseOf rdf:resource="http://ns.inria.fr/pgxo/isIncreasedBy"/>
        <rdfs:label xml:lang="en">increases</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/increasesChanceOf -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/increasesChanceOf">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/influences"/>
        <rdfs:label xml:lang="en">increases chance of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/influences -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/influences">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isAssociatedWith"/>
        <owl:inverseOf rdf:resource="http://ns.inria.fr/pgxo/isInfluencedBy"/>
        <rdfs:label xml:lang="en">influences</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/isAssociatedWith -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/isAssociatedWith">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:label xml:lang="en">is associated with</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/isCausedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/isCausedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isInfluencedBy"/>
        <rdfs:label xml:lang="en">is caused by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/isDecreasedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/isDecreasedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isInfluencedBy"/>
        <rdfs:label xml:lang="en">is decreased by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/isIncreasedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/isIncreasedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isInfluencedBy"/>
        <rdfs:label xml:lang="en">is increased by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/isInfluencedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/isInfluencedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isAssociatedWith"/>
        <rdfs:label xml:lang="en">is influenced by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/isMetabolizedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/isMetabolizedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isInfluencedBy"/>
        <owl:inverseOf rdf:resource="http://ns.inria.fr/pgxo/metabolizes"/>
        <rdfs:label xml:lang="en">is metabolized by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/isNotAssociatedWith -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/isNotAssociatedWith">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:label xml:lang="en">is not associated with</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/isNotCausedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/isNotCausedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isNotInfluencedBy"/>
        <rdfs:label xml:lang="en">is not caused by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/isNotDecreasedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/isNotDecreasedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isNotInfluencedBy"/>
        <rdfs:label xml:lang="en">is not decreased by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/isNotIncreasedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/isNotIncreasedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isNotInfluencedBy"/>
        <rdfs:label xml:lang="en">is not increased by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/isNotInfluencedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/isNotInfluencedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isNotAssociatedWith"/>
        <rdfs:label xml:lang="en">is not influenced by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/isNotMetabolizedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/isNotMetabolizedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isNotInfluencedBy"/>
        <rdfs:label xml:lang="en">is not metabolized by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/isNotTransportedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/isNotTransportedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isNotInfluencedBy"/>
        <rdfs:label xml:lang="en">is not transported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/isNotTreatedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/isNotTreatedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isNotAssociatedWith"/>
        <rdfs:label xml:lang="en">is not treated by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/isTransportedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/isTransportedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isInfluencedBy"/>
        <owl:inverseOf rdf:resource="http://ns.inria.fr/pgxo/transports"/>
        <rdfs:label xml:lang="en">is transported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/isTreatedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/isTreatedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isAssociatedWith"/>
        <owl:inverseOf rdf:resource="http://ns.inria.fr/pgxo/treats"/>
        <rdfs:label xml:lang="en">is treated by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/metabolizes -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/metabolizes">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/influences"/>
        <rdfs:label xml:lang="en">metabolizes</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/qualifiedProxy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/qualifiedProxy">
