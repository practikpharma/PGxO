        <rdfs:label xml:lang="en">does not influence</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/doesNotMetabolize -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/doesNotMetabolize">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/doesNotInfluence"/>
