        <rdfs:label xml:lang="en">has chance increased by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/hasNotChanceDecreasedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/hasNotChanceDecreasedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isNotInfluencedBy"/>
        <rdfs:label xml:lang="en">has not chance decreased by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/hasNotChanceIncreasedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/hasNotChanceIncreasedBy">
