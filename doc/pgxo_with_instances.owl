     -->

    


    <!-- http://ns.inria.fr/pgxo/clinPGxLevelOfEvidence -->

    <owl:DatatypeProperty rdf:about="http://ns.inria.fr/pgxo/clinPGxLevelOfEvidence">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://ns.inria.fr/pgxo/PharmacogenomicRelationship"/>
        <rdfs:label xml:lang="en">level of evidence in ClinPGx</rdfs:label>
    </owl:DatatypeProperty>
    


