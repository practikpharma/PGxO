<?xml version="1.0"?>
<rdf:RDF xmlns="http://ns.inria.fr/pgxo/"
     xml:base="http://ns.inria.fr/pgxo/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:ro="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:pgxo="http://ns.inria.fr/pgxo/"
     xmlns:prov="http://www.w3.org/ns/prov#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://ns.inria.fr/pgxo/">
        <dc:creator>Adrien Coulet (Inria, Inserm, Université Paris Cité, HeKA UMR1346, Paris, France)</dc:creator>
        <dc:creator>Clément Jonquet (MISTEA, Université de Montpellier, Institut Agro, INRAE, Montpellier, France, and LIRMM, Université de Montpellier, Montpellier, France)</dc:creator>
        <dc:creator>Pierre Monnin (Université Côte d&apos;Azur, Inria, CNRS, I3S, Sophia-Antipolis, France)</dc:creator>
        <dc:license>https://creativecommons.org/licenses/by-nc/4.0/</dc:license>
        <rdfs:comment xml:lang="en">- Move namespace from http://pgxo.loria.fr/ to http://ns.inria.fr/pgxo/
- Remove usage of DUL
- Add a new data property to connect pharmacogenomic relationships to their level of evidence in ClinPGx</rdfs:comment>
        <rdfs:comment xml:lang="en">PGxO aims at providing a small set of concepts and roles that may type elements of pharmacogenomic relationships.</rdfs:comment>
        <rdfs:label xml:lang="en">PGxO: a lite Pharmacogenomic Ontology</rdfs:label>
        <owl:versionInfo>0.6</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/license"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://ns.inria.fr/pgxo/causes -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/causes">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/influences"/>
        <owl:inverseOf rdf:resource="http://ns.inria.fr/pgxo/isCausedBy"/>
        <rdfs:label xml:lang="en">causes</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/decreases -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/decreases">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/influences"/>
        <owl:inverseOf rdf:resource="http://ns.inria.fr/pgxo/isDecreasedBy"/>
        <rdfs:label xml:lang="en">decreases</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/decreasesChanceOf -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/decreasesChanceOf">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/influences"/>
        <owl:inverseOf rdf:resource="http://ns.inria.fr/pgxo/hasChanceDecreasedBy"/>
        <rdfs:label xml:lang="en">decreases chance of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/doesNotCause -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/doesNotCause">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/doesNotInfluence"/>
        <owl:inverseOf rdf:resource="http://ns.inria.fr/pgxo/isNotCausedBy"/>
        <rdfs:label xml:lang="en">does not cause</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/doesNotDecrease -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/doesNotDecrease">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/doesNotInfluence"/>
        <owl:inverseOf rdf:resource="http://ns.inria.fr/pgxo/isNotDecreasedBy"/>
        <rdfs:label xml:lang="en">does not decrease</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/doesNotDecreaseChanceOf -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/doesNotDecreaseChanceOf">
