    <!-- http://ns.inria.fr/pgxo/doesNotInfluence -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/doesNotInfluence">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isNotAssociatedWith"/>
