    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/doesNotIncreaseChanceOf -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/doesNotIncreaseChanceOf">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/doesNotInfluence"/>
        <owl:inverseOf rdf:resource="http://ns.inria.fr/pgxo/hasNotChanceIncreasedBy"/>
        <rdfs:label xml:lang="en">does not increase chance of</rdfs:label>
