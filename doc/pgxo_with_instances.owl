        <rdfs:label xml:lang="en">transports</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/treats -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/treats">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isAssociatedWith"/>
