        <rdfs:label xml:lang="en">does not metabolize</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/doesNotTransport -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/doesNotTransport">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/doesNotInfluence"/>
        <owl:inverseOf rdf:resource="http://ns.inria.fr/pgxo/isNotTransportedBy"/>
        <rdfs:label xml:lang="en">does not transport</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/doesNotTreat -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/doesNotTreat">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isNotAssociatedWith"/>
        <owl:inverseOf rdf:resource="http://ns.inria.fr/pgxo/isNotTreatedBy"/>
        <rdfs:label xml:lang="en">does not treat</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/hasChanceDecreasedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/hasChanceDecreasedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isInfluencedBy"/>
        <rdfs:label xml:lang="en">has chance decreased by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://ns.inria.fr/pgxo/hasChanceIncreasedBy -->

    <owl:ObjectProperty rdf:about="http://ns.inria.fr/pgxo/hasChanceIncreasedBy">
        <rdfs:subPropertyOf rdf:resource="http://ns.inria.fr/pgxo/isInfluencedBy"/>
